# Neon — Project → Connection string (psql or pooled). Use the pooled string on Vercel Serverless.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Optional: seed demo rows for an existing user (npm run db:seed). Re-run with SEED_FORCE=1.
# SEED_USER_EMAIL="you@example.com"
# SEED_FORCE="1"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"
# Optional; Vercel sets automatically. Local: http://localhost:3000
# AUTH_URL="http://localhost:3000"

# Optional — shown in the site footer ("Created by …"). Override without editing code.
# NEXT_PUBLIC_APP_AUTHOR_NAME="Your Name"

# Optional Google OAuth (omit both to disable). Callback: {AUTH_URL}/api/auth/callback/google
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# Finance data encryption (AES-256-GCM): transactions, transfers, lending, account names,
# recurring template names and fixed amounts, etc. Categories and user name/email stay plaintext. Same key on every deploy.
# Generate: openssl rand -hex 32
TRANSACTIONS_ENCRYPTION_KEY="paste-64-char-hex-here"

# Optional: conversion rate for USD<->PHP account balance display when navbar currency differs.
# Example: if 1 USD = 56.50 PHP, set USD_TO_PHP_RATE="56.5"
# USD_TO_PHP_RATE="56"

# Optional: protect /api/cron/fx-rates (Vercel cron sends this as Bearer token).
# CRON_SECRET="set-a-random-long-secret"

# Password reset emails — Google (Gmail) SMTP (recommended for OTP).
# Use a Google Account App Password: Google Account → Security → 2-Step Verification → App passwords.
# SMTP_USER is your full Gmail address; SMTP_PASS is the 16-character app password (not your normal password).
# SMTP_HOST defaults to smtp.gmail.com; SMTP_PORT defaults to 587 (STARTTLS).
# EMAIL_FROM can be your address or "MIDAS Finance Tracker <you@gmail.com>".
#
# SMTP_USER="you@gmail.com"
# SMTP_PASS="xxxx xxxx xxxx xxxx"
# EMAIL_FROM="MIDAS Finance Tracker <you@gmail.com>"
# Optional overrides:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# For port 465 SSL: SMTP_PORT="465" and SMTP_SECURE="true"

# Alternative: Resend (if you prefer not to use SMTP).
# RESEND_API_KEY=""
# EMAIL_FROM="MIDAS Finance Tracker <onboarding@resend.dev>"
